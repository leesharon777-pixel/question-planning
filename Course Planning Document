<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>질문으로 하는 기획력 — 과정 기획안</title>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable.min.css">
<style>
:root{--purple:#534AB7;--purple-light:#EEEDFE;--purple-dark:#3C3489;--teal:#1D9E75;--teal-light:#E1F5EE;--teal-dark:#085041;--coral:#D85A30;--coral-light:#FAECE7;--amber:#BA7517;--amber-light:#FAEEDA;--amber-dark:#633806;--blue:#378ADD;--blue-light:#E6F1FB;--gray-50:#F8F7F4;--gray-100:#F1EFE8;--gray-200:#D3D1C7;--gray-400:#888780;--gray-600:#5F5E5A;--text:#1A1A1A;--text-secondary:#6B6B6B;--text-tertiary:#9B9B9B;--border:rgba(0,0,0,0.07)}
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:'Pretendard Variable',-apple-system,BlinkMacSystemFont,sans-serif;color:var(--text);background:#FDFCFA;line-height:1.75;font-size:15px;-webkit-font-smoothing:antialiased}
@media print{body{background:#fff;font-size:13px}.no-print{display:none!important}.page-break{page-break-before:always}section{break-inside:avoid}}
.container{max-width:820px;margin:0 auto;padding:0 32px}
.cover{min-height:55vh;display:flex;flex-direction:column;justify-content:center;padding:80px 0 48px;border-bottom:1px solid var(--border)}
.cover-label{font-size:12px;font-weight:600;letter-spacing:2px;text-transform:uppercase;color:var(--purple);margin-bottom:24px}
.cover h1{font-size:42px;font-weight:700;line-height:1.25;letter-spacing:-1px;margin-bottom:16px}
.cover h1 em{font-style:normal;color:var(--purple)}
.cover-sub{font-size:18px;color:var(--text-secondary);line-height:1.6;max-width:560px}
.cover-meta{margin-top:48px;display:flex;gap:32px;font-size:13px;color:var(--text-secondary)}
.cover-meta strong{color:var(--text);font-weight:500}
.toc{padding:48px 0;border-bottom:1px solid var(--border)}
.toc h2{font-size:13px;font-weight:600;letter-spacing:1.5px;text-transform:uppercase;color:var(--gray-400);margin-bottom:20px}
.toc-list{list-style:none;counter-reset:toc}
.toc-list li{counter-increment:toc;padding:10px 0;border-bottom:1px solid var(--border);display:flex;align-items:baseline;gap:12px}
.toc-list li::before{content:"0" counter(toc);font-size:12px;font-weight:600;color:var(--purple);min-width:24px}
.toc-list a{color:var(--text);text-decoration:none;font-weight:500;font-size:15px}
.toc-list a:hover{color:var(--purple)}
section{padding:56px 0;border-bottom:1px solid var(--border)}
.section-num{font-size:12px;font-weight:600;letter-spacing:1.5px;color:var(--purple);margin-bottom:8px}
section h2{font-size:28px;font-weight:700;line-height:1.3;letter-spacing:-.5px;margin-bottom:12px}
section h3{font-size:18px;font-weight:600;margin:36px 0 12px}
section h4{font-size:15px;font-weight:600;margin-bottom:6px}
section p{color:var(--text-secondary);margin-bottom:16px}
section p.lead{font-size:16px;color:var(--text);line-height:1.8}
.card{background:#fff;border:1px solid var(--border);border-radius:12px;padding:24px 28px;margin:16px 0}
.card-accent{border-left:3px solid var(--purple)}
.card p{font-size:14px;margin-bottom:8px}
.badge{display:inline-block;font-size:11px;font-weight:600;padding:3px 10px;border-radius:20px}
.badge-purple{background:var(--purple-light);color:var(--purple-dark)}
.badge-teal{background:var(--teal-light);color:var(--teal-dark)}
.badge-coral{background:var(--coral-light);color:var(--coral)}
.badge-amber{background:var(--amber-light);color:var(--amber-dark)}
.badge-blue{background:var(--blue-light);color:var(--blue)}
.badge-gray{background:var(--gray-100);color:var(--gray-600)}
.summary-box{background:var(--purple-light);border-radius:14px;padding:28px;margin:24px 0}
.summary-box h4{font-size:16px;font-weight:600;color:var(--purple-dark);margin-bottom:14px}
.summary-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px}
.summary-item .s-label{font-size:11px;font-weight:600;color:var(--purple);margin-bottom:2px}
.summary-item .s-value{font-size:14px;color:var(--purple-dark);margin:0}
.matrix-table{width:100%;border-collapse:separate;border-spacing:0;margin:20px 0;font-size:13px}
.matrix-table th{background:var(--gray-50);font-weight:600;padding:12px 14px;text-align:left;border-bottom:2px solid var(--gray-200)}
.matrix-table td{padding:14px;border-bottom:1px solid var(--border);vertical-align:top}
.matrix-table tr:last-child td{border-bottom:none}
.cell-core{background:var(--purple-light);border-radius:8px;padding:10px 12px!important;font-weight:500}
.cell-phase2{background:var(--teal-light);border-radius:8px;padding:10px 12px!important}
.cell-phase3{background:var(--gray-100);border-radius:8px;padding:10px 12px!important;color:var(--gray-400)}
.roadmap-cards{display:grid;grid-template-columns:repeat(3,1fr);gap:14px;margin:20px 0}
.roadmap-card{border-radius:12px;padding:20px;border:1px solid var(--border)}
.roadmap-card h4{font-size:14px;font-weight:600;margin-bottom:6px}
.roadmap-card p{font-size:12px;margin:0}
.rc-purple{background:var(--purple-light);border-color:rgba(83,74,183,.15)}.rc-purple h4{color:var(--purple-dark)}.rc-purple p{color:var(--purple)}
.rc-teal{background:var(--teal-light);border-color:rgba(29,158,117,.15)}.rc-teal h4{color:var(--teal-dark)}.rc-teal p{color:var(--teal)}
.rc-gray{background:var(--gray-100);border-color:var(--gray-200)}.rc-gray h4{color:var(--gray-600)}.rc-gray p{color:var(--gray-400)}
.journey-flow{display:flex;align-items:stretch;gap:0;margin:28px 0;overflow-x:auto}
.journey-step{flex:1;min-width:120px;position:relative;text-align:center;padding:0 6px}
.journey-step-inner{background:#fff;border:1px solid var(--border);border-radius:12px;padding:18px 12px;height:100%;display:flex;flex-direction:column;align-items:center;gap:6px}
.journey-num{width:32px;height:32px;border-radius:50%;background:var(--purple-light);color:var(--purple-dark);font-size:14px;font-weight:700;display:flex;align-items:center;justify-content:center}
.journey-title{font-size:13px;font-weight:600;line-height:1.3}
.journey-output{font-size:11px;color:var(--teal);font-weight:500;background:var(--teal-light);padding:2px 8px;border-radius:10px;margin-top:auto}
.journey-arrow{position:absolute;right:-12px;top:50%;transform:translateY(-50%);z-index:1;color:var(--gray-200);font-size:18px}
.journey-step:last-child .journey-arrow{display:none}
.chain-visual{background:var(--gray-50);border-radius:14px;padding:24px;margin:24px 0;border:1px solid var(--border)}
.chain-row{display:flex;align-items:center;gap:8px;padding:8px 0;font-size:13px}
.chain-mod{width:28px;height:28px;border-radius:8px;background:var(--purple-light);color:var(--purple-dark);font-size:11px;font-weight:700;display:flex;align-items:center;justify-content:center;flex-shrink:0}
.chain-arrow-down{width:28px;display:flex;justify-content:center;color:var(--gray-200);font-size:14px;padding:2px 0}
.chain-output{flex:1;background:#fff;border:1px solid var(--border);border-radius:8px;padding:8px 12px;font-size:13px}
.chain-inject{font-size:11px;color:var(--amber);font-weight:500;background:var(--amber-light);padding:2px 8px;border-radius:10px;white-space:nowrap}
.module-grid{display:flex;flex-direction:column;gap:16px;margin:24px 0}
.module-card{background:#fff;border:1px solid var(--border);border-radius:14px;padding:28px;display:grid;grid-template-columns:48px 1fr;gap:20px}
.module-num{width:48px;height:48px;border-radius:12px;background:var(--purple-light);color:var(--purple-dark);font-size:18px;font-weight:700;display:flex;align-items:center;justify-content:center}
.module-content h4{font-size:17px;font-weight:600;margin-bottom:4px}
.module-content .module-sub{font-size:13px;color:var(--text-secondary);margin-bottom:12px}
.module-detail-row{display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px;margin-top:14px}
.module-detail{background:var(--gray-50);border-radius:8px;padding:12px 14px}
.module-detail .label{font-size:11px;font-weight:600;margin-bottom:4px}
.module-detail .label-fw{color:var(--purple)}.module-detail .label-practice{color:var(--amber)}.module-detail .label-output{color:var(--teal)}
.module-detail .value{font-size:13px;color:var(--text-secondary);margin:0}
.module-time{display:flex;align-items:center;gap:6px;margin-top:12px;font-size:12px;color:var(--text-tertiary)}
.time-bar{flex:1;height:6px;border-radius:3px;background:var(--gray-100);overflow:hidden;display:flex}
.time-fill{height:100%}
.time-fill-learn{background:var(--purple-light)}.time-fill-practice{background:var(--amber-light)}.time-fill-output{background:var(--teal-light)}
.pace-grid{display:grid;grid-template-columns:1fr 1fr 1fr;gap:14px;margin:20px 0}
.pace-card{background:#fff;border:1px solid var(--border);border-radius:12px;padding:20px}
.pace-card h4{font-size:14px;font-weight:600;margin-bottom:4px}
.pace-card .pace-duration{font-size:22px;font-weight:700;color:var(--purple);margin-bottom:8px}
.pace-card p{font-size:12px;margin:0}
.pace-card .pace-tag{display:inline-block;font-size:11px;font-weight:500;padding:2px 8px;border-radius:10px;margin-top:8px}
.callout{background:var(--amber-light);border-radius:12px;padding:20px 24px;margin:20px 0}
.callout h4{color:var(--amber-dark);font-size:14px;margin-bottom:6px}
.callout p{color:var(--amber);font-size:13px;margin:0}
.mockup-container{background:var(--gray-50);border-radius:16px;padding:20px;margin:24px 0;border:1px solid var(--border)}
.mockup-label{font-size:11px;font-weight:600;letter-spacing:1px;color:var(--gray-400);margin-bottom:14px;text-transform:uppercase}
.mockup-screen{background:#fff;border-radius:12px;border:1px solid var(--border);overflow:hidden}
.mockup-header{background:var(--gray-50);padding:10px 16px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:8px}
.mockup-header-dot{width:8px;height:8px;border-radius:50%;background:var(--gray-200)}
.mockup-body{padding:20px}
.chat-msg{display:flex;gap:10px;margin-bottom:14px}
.chat-msg-ai .chat-bubble{background:var(--gray-50);border:1px solid var(--border);border-radius:2px 12px 12px 12px;padding:14px 16px;font-size:13px;line-height:1.7;max-width:85%}
.chat-msg-user{justify-content:flex-end}
.chat-msg-user .chat-bubble{background:var(--purple-light);color:var(--purple-dark);border-radius:12px 2px 12px 12px;padding:14px 16px;font-size:13px;line-height:1.7;max-width:80%}
.chat-avatar{width:28px;height:28px;border-radius:50%;background:var(--purple-light);display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:600;color:var(--purple-dark);flex-shrink:0}
.chat-step-badge{display:inline-block;font-size:11px;font-weight:600;padding:2px 8px;border-radius:10px;background:var(--amber-light);color:var(--amber-dark);margin-bottom:8px}
.chat-tree{background:#fff;border-radius:8px;padding:10px 14px;margin:10px 0 4px;font-size:12px;font-family:'Pretendard Variable',monospace;line-height:1.8}
.chat-tree .root{color:var(--purple);font-weight:600}
.chat-tree .branch{color:var(--blue)}
.suggest-chips{display:flex;gap:6px;flex-wrap:wrap;margin-top:10px}
.chip{font-size:12px;padding:5px 12px;border-radius:20px;border:1px solid var(--gray-200);background:#fff}
.score-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;margin:14px 0}
.score-item{background:var(--gray-50);border-radius:10px;padding:14px;text-align:center}
.score-num{font-size:26px;font-weight:700;margin-bottom:2px}
.score-label{font-size:11px;color:var(--text-secondary)}
.doc-section-row{padding:12px 0;border-bottom:1px solid var(--border)}
.doc-section-row:last-child{border-bottom:none}
.doc-section-head{display:flex;align-items:center;gap:8px;margin-bottom:4px}
.doc-section-title{font-size:14px;font-weight:600}
.doc-section-text{font-size:13px;color:var(--text-secondary);margin:0}
.doc-highlight{background:var(--gray-50);border-radius:8px;padding:10px 14px;margin-top:8px;font-size:13px;font-weight:500}
.feedback-row{display:flex;align-items:start;gap:8px;padding:5px 0;font-size:13px}
.fb-dot{width:18px;height:18px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:700;flex-shrink:0;margin-top:1px}
.fb-good{background:var(--teal-light);color:var(--teal)}
.fb-improve{background:var(--amber-light);color:var(--amber)}
.checklist{list-style:none;margin:12px 0}
.checklist li{display:flex;align-items:start;gap:10px;padding:6px 0;font-size:14px;color:var(--text-secondary)}
.check-icon{width:18px;height:18px;border-radius:5px;border:1.5px solid var(--gray-200);flex-shrink:0;margin-top:2px;display:flex;align-items:center;justify-content:center}
.check-icon.done{background:var(--purple);border-color:var(--purple);color:#fff;font-size:10px}
.timeline{position:relative;padding-left:36px;margin:24px 0}
.timeline::before{content:'';position:absolute;left:14px;top:4px;bottom:4px;width:1px;background:var(--gray-200)}
.timeline-item{position:relative;padding-bottom:28px}
.timeline-item:last-child{padding-bottom:0}
.timeline-dot{position:absolute;left:-29px;top:4px;width:14px;height:14px;border-radius:50%;border:2px solid #fff}
.timeline-dot-purple{background:var(--purple)}.timeline-dot-teal{background:var(--teal)}.timeline-dot-amber{background:var(--amber)}
.timeline-item h4{font-size:15px;font-weight:600;margin-bottom:4px}
.timeline-item p{font-size:13px;color:var(--text-secondary);margin:0}
.doc-footer{padding:40px 0;text-align:center;font-size:12px;color:var(--gray-400)}
@media(max-width:640px){.container{padding:0 20px}.cover h1{font-size:28px}.module-card{grid-template-columns:1fr}.module-detail-row,.score-grid,.summary-grid,.roadmap-cards,.pace-grid{grid-template-columns:1fr}.cover-meta{flex-direction:column;gap:8px}.journey-flow{flex-direction:column}.journey-arrow{display:none!important}}
</style>
</head>
