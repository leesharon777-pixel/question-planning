<script>
// Scroll spy — 현재 보고 있는 섹션의 탭을 활성화
(function() {
  const tabs = document.querySelectorAll('.tab-item');
  const sections = Array.from(tabs).map(tab => {
    const id = tab.getAttribute('data-section');
    return { id, el: document.getElementById(id), tab };
  }).filter(s => s.el);

  function updateActiveTab() {
    const scrollY = window.scrollY + 120;
    let activeId = sections[0].id;
    for (const s of sections) {
      if (s.el.offsetTop <= scrollY) activeId = s.id;
    }
    tabs.forEach(t => {
      t.classList.toggle('active', t.getAttribute('data-section') === activeId);
    });
  }

  // 부드러운 스크롤
  tabs.forEach(tab => {
    tab.addEventListener('click', function(e) {
      e.preventDefault();
      const id = this.getAttribute('data-section');
      const el = document.getElementById(id);
      if (el) {
        const top = el.offsetTop - 70;
        window.scrollTo({ top, behavior: 'smooth' });
      }
    });
  });

  let ticking = false;
  window.addEventListener('scroll', () => {
    if (!ticking) {
      window.requestAnimationFrame(() => {
        updateActiveTab();
        ticking = false;
      });
      ticking = true;
    }
  });
  updateActiveTab();
})();
</script>

